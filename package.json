{
  "name": "expense-tracker-pro",
  "private": true,
  "version": "1.0.0",
  "description": "Production-grade personal finance management application",
  "type": "module",
  "scripts": {
    "dev": "node node_modules/vite/bin/vite.js",
    "build": "node node_modules/typescript/bin/tsc -p tsconfig.app.json && node node_modules/vite/bin/vite.js build",
    "preview": "node node_modules/vite/bin/vite.js preview",
    "lint": "node node_modules/eslint/bin/eslint.js .",
    "lint:fix": "node node_modules/eslint/bin/eslint.js . --fix",
    "format": "node node_modules/prettier/bin/prettier.cjs --write \"src/**/*.{ts,tsx,json,css}\"",
    "format:check": "node node_modules/prettier/bin/prettier.cjs --check \"src/**/*.{ts,tsx,json,css}\"",
    "test": "node node_modules/vitest/vitest.mjs",
    "test:ui": "node node_modules/vitest/vitest.mjs --ui",
    "test:coverage": "node node_modules/vitest/vitest.mjs run --coverage",
    "generate-icons": "node scripts/generate-icons.mjs",
    "prepare-husky": "husky"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@hookform/resolvers": "^5.0.1",
    "@mui/icons-material": "^7.1.1",
    "@mui/lab": "^7.0.0-beta.14",
    "@mui/material": "^7.1.1",
    "@mui/x-date-pickers": "^8.4.0",
    "@reduxjs/toolkit": "^2.6.1",
    "dayjs": "^1.11.13",
    "dexie": "^4.0.10",
    "dexie-react-hooks": "^1.1.7",
    "i18next": "^25.2.1",
    "jspdf": "^2.5.2",
    "jspdf-autotable": "^3.8.4",
    "notistack": "^3.0.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.56.4",
    "react-i18next": "^15.5.2",
    "react-redux": "^9.2.0",
    "react-router": "^7.6.2",
    "recharts": "^2.15.3",
    "xlsx": "^0.18.5",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jspdf": "^2.0.0",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^3.2.3",
    "@vitest/ui": "^3.2.3",
    "eslint": "^9.28.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.2.0",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "lint-staged": "^15.5.2",
    "prettier": "^3.5.3",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.34.0",
    "vite": "^8.0.12",
    "vite-plugin-pwa": "^1.0.0",
    "vitest": "^3.2.3"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.{json,css}": [
      "prettier --write"
    ]
  },
  "allowScripts": {
    "esbuild@0.27.7": true,
    "core-js@3.49.0": true
  }
}
